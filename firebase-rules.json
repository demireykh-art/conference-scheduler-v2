{
  "rules": {
    "eventList": {
      ".read": "auth != null",
      "$eventId": {
        ".write": "auth != null && (!data.exists() || data.child('members').child(auth.uid).val() === 'admin' || data.child('createdBy').val() === auth.token.email)"
      }
    },

    "events": {
      "$eventId": {
        ".read": "auth != null && root.child('eventList').child($eventId).child('members').child(auth.uid).exists()",
        "data": {
          ".write": "auth != null && (root.child('eventList').child($eventId).child('members').child(auth.uid).val() === 'admin' || root.child('eventList').child($eventId).child('members').child(auth.uid).val() === 'editor')"
        },
        "settings": {
          ".write": "auth != null && (root.child('eventList').child($eventId).child('members').child(auth.uid).val() === 'admin' || root.child('eventList').child($eventId).child('members').child(auth.uid).val() === 'editor')"
        },
        "backups": {
          ".write": "auth != null && (root.child('eventList').child($eventId).child('members').child(auth.uid).val() === 'admin' || root.child('eventList').child($eventId).child('members').child(auth.uid).val() === 'editor')"
        },
        "locks": {
          ".write": "auth != null && root.child('eventList').child($eventId).child('members').child(auth.uid).exists()"
        },
        "history": {
          "$date": {
            ".read": "auth != null && root.child('eventList').child($eventId).child('members').child(auth.uid).exists()",
            ".write": "auth != null && (root.child('eventList').child($eventId).child('members').child(auth.uid).val() === 'admin' || root.child('eventList').child($eventId).child('members').child(auth.uid).val() === 'editor')"
          }
        }
      }
    },

    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "presence": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
